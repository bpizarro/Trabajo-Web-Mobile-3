# NexoForm – Variables de entorno
# Copia este archivo como .env.local y ajusta
# los valores. NUNCA subas .env.local al repo.
# ─────────────────────────────────────────────

# Credenciales del administrador
# ADVERTENCIA: en una app real estas credenciales
# deben validarse en un backend seguro, nunca en
# el cliente. Esto es solo para demostración local.
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=nexo2026

# Clave de almacenamiento localStorage
VITE_STORAGE_KEY=nexoform_entries
VITE_THEME_KEY=nexoform_theme
